{
  "permissions": {
    "allow": [
      "Bash(grep -rn *)",
      "Bash(find . -name \"*.md\" *)",
      "Bash(curl -s -X GET *)",
      "Bash(curl -s -X POST *)",
      "Bash(python3 -c \"import feedparser\")",
      "Bash(./venv/bin/python -c ' *)",
      "Bash(/Users/arthurkeen/code/AWS_Ontology/venv/bin/python -c ' *)",
      "Bash(echo \"---exit $?\")",
      "Bash(python3 -c 'import rdflib; print\\(rdflib.__version__\\)')",
      "Bash(python3 -m venv rv)",
      "Bash(./rv/bin/pip -q install rdflib)",
      "Bash(git -C /Users/arthurkeen/code/AWS_Ontology log --format='%ad %h %s' --date=short)",
      "Bash(git -C /Users/arthurkeen/code/AWS_Ontology log -1 --format='%ad' --date=short -- ontology/)",
      "Bash(/private/tmp/claude-501/-Users-arthurkeen-code-AWS-Ontology/36b622c8-d647-444a-8ba0-b89266bfbc49/scratchpad/rv/bin/python -m unittest tests.test_ontology_quality tests.test_examples_validation tests.test_format_sync)",
      "Bash(python3 -c \"import rdflib; print\\(rdflib.__version__\\)\")",
      "Bash(python3 tools/sync_formats.py --help)",
      "Bash(python3 -m venv /private/tmp/claude-501/-Users-arthurkeen-code-AWS-Ontology/36b622c8-d647-444a-8ba0-b89266bfbc49/scratchpad/venv)",
      "Bash(/private/tmp/claude-501/-Users-arthurkeen-code-AWS-Ontology/36b622c8-d647-444a-8ba0-b89266bfbc49/scratchpad/venv/bin/pip install *)",
      "Bash(/private/tmp/claude-501/-Users-arthurkeen-code-AWS-Ontology/36b622c8-d647-444a-8ba0-b89266bfbc49/scratchpad/venv/bin/python -c \"import rdflib; print\\('rdflib', rdflib.__version__\\)\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(python3 -c \"import sys,json; d=json.load(sys.stdin); ti=d.get(\\\"tool_input\\\",d); print(ti.get(\\\"file_path\\\",ti.get(\\\"path\\\",\\\"\\\")))\" 2>/dev/null); if [ -z \"$FILE\" ]; then exit 0; fi; if echo \"$FILE\" | grep -qE \"\\.(ts|js|tsx|jsx|py|go|rs|java|cs|cpp|c|rb|php|swift|kt|ttl|owl)$\"; then mkdir -p .prd-drift-queue && touch \".prd-drift-queue/$(date +%s)_$(basename $FILE)\"; echo \"[PRD-DRIFT] Implementation file modified: $(basename $FILE). Run /prd-sync to verify spec alignment.\"; fi'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'DRIFTS=$(ls .prd-drift-queue 2>/dev/null | wc -l | tr -d \" \"); if [ \"$DRIFTS\" -gt 0 ] 2>/dev/null; then echo \"[PRD-DRIFT] $DRIFTS implementation changes queued since last /prd-sync. Run /prd-sync before ending session.\"; fi'"
          }
        ]
      }
    ]
  }
}
